# ITQAN ERP Environment Configuration

# Database Mode: LOCAL (SQLite) or SAAS (PostgreSQL)
DATABASE_MODE=SAAS
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# JWT Secrets
JWT_SECRET="generate_a_strong_secret_key_here"
JWT_REFRESH_SECRET="generate_a_strong_refresh_secret_key_here"

# Super Admin Initial Credentials
SUPER_ADMIN_EMAIL="admin@accounting.local"
SUPER_ADMIN_PASSWORD="secure_password_here"

# Server Config
PORT=3000
APP_URL="http://localhost:3000"
GEMINI_API_KEY=""

# Vercel / Deployment
NODE_ENV=production
