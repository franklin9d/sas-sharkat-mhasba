# ITQAN ERP Environment Configuration

# Database Mode: LOCAL, PRIVATE_SERVER, SAAS
DATABASE_MODE=LOCAL

# JWT Secrets (Generated automatically in production, but you can set them)
JWT_SECRET="JWT_SECRET_VALUE"
JWT_REFRESH_SECRET="JWT_REFRESH_SECRET_VALUE"

# Super Admin Initial Credentials
SUPER_ADMIN_EMAIL="admin@itqan.com"
SUPER_ADMIN_PASSWORD="admin_password_here"

# Server Config
PORT=3000
APP_URL="MY_APP_URL"
GEMINI_API_KEY="MY_GEMINI_API_KEY"
